{
  "version": 8,
  "name": "Africapolis Base",
  "metadata": { "mapbox:autocomposite": true, "mapbox:type": "template" },
  "center": [18.5, 0],
  "zoom": 3,
  "sprite": "mapbox://sprites/mapbox/light-v11",
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "sources": {
    "composite": {
      "type": "vector",
      "url": "mapbox://mapbox.mapbox-streets-v8"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#e8e4dc" }
    },
    {
      "id": "national_park",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse_overlay",
      "minzoom": 5,
      "filter": ["==", ["get", "class"], "national_park"],
      "paint": { "fill-color": "hsl(90, 25%, 82%)", "fill-opacity": 0.6 }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "minzoom": 5,
      "filter": ["match", ["get", "class"], ["park", "pitch", "grass", "scrub", "agriculture"], true, false],
      "paint": { "fill-color": "hsl(85, 20%, 85%)", "fill-opacity": ["interpolate", ["linear"], ["zoom"], 5, 0, 6, 0.5] }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "composite",
      "source-layer": "waterway",
      "minzoom": 8,
      "filter": ["all", ["==", ["geometry-type"], "LineString"], ["in", ["get", "class"], ["literal", ["canal", "river"]]]],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": {
        "line-color": "hsl(200, 15%, 65%)",
        "line-width": ["interpolate", ["exponential", 1.3], ["zoom"], 8.5, 0.1, 20, 8]
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "composite",
      "source-layer": "water",
      "paint": { "fill-color": "hsl(200, 12%, 78%)" }
    },
    {
      "id": "road",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 5,
      "filter": ["all", ["==", ["geometry-type"], "LineString"], ["match", ["get", "structure"], ["none", "ford"], true, false]],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": {
        "line-color": ["match", ["get", "class"], ["primary_link", "secondary_link", "tertiary_link", "street", "street_limited", "service", "track"], "hsl(35, 12%, 78%)", "hsl(35, 8%, 88%)"],
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 5, 0.5, 18, 20]
      }
    },
    {
      "id": "admin-country",
      "type": "line",
      "source": "composite",
      "source-layer": "admin",
      "minzoom": 1,
      "filter": ["all", ["==", ["get", "admin_level"], 0], ["!=", ["get", "maritime"], "true"]],
      "paint": {
        "line-color": "hsl(0, 0%, 50%)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 0.5, 10, 2]
      }
    },
    {
      "id": "place_label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "minzoom": 0,
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 12, 10, 16]
      },
      "paint": {
        "text-color": "hsl(0, 0%, 25%)",
        "text-halo-color": "hsla(0, 0%, 100%, 0.9)",
        "text-halo-width": 1.5
      }
    }
  ]
}
